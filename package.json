{
  "name": "@ovi1kanobe/pbov",
  "version": "1.0.0",
  "description": "A React component library for PocketBase Applications",
  "exports": {
    ".": "./dist/index.js",
    "./styles.css": "./dist/styles/index.css"
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:clean && bun tsc && bun run build:styles",
    "build:clean": "rm -rf ./dist/*",
    "build:styles": "bunx @tailwindcss/cli -i ./src/styles/index.css -o ./dist/styles/index.css --minify",
    "preview": "vite preview"
  },
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^5.2.0",
    "vite": "^7.3.5"
  },
  "peerDependencies": {
    "pocketbase": "^0.26.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react-colorful": "^5.7.0",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "sideEffects": ["**/*.css"]
}
